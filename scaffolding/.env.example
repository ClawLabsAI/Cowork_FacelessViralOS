# ==============================================================================
# Faceless Viral OS — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# ------------------------------------------------------------------------------
# Database (PostgreSQL)
# ------------------------------------------------------------------------------
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://fvos:fvos_password@localhost:5432/fvos_dev?schema=public

# ------------------------------------------------------------------------------
# Redis (BullMQ job queues + caching)
# ------------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ------------------------------------------------------------------------------
# Authentication
# ------------------------------------------------------------------------------
# Must be a long, random string — generate with: openssl rand -base64 64
JWT_SECRET=replace_me_with_a_secure_random_string_at_least_64_chars_long
JWT_EXPIRES_IN=7d
# Optional: separate secret for refresh tokens
JWT_REFRESH_SECRET=replace_me_with_another_secure_random_string
JWT_REFRESH_EXPIRES_IN=30d

# ------------------------------------------------------------------------------
# AI Providers — LLM
# ------------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...
GOOGLE_AI_API_KEY=AIza...

# ------------------------------------------------------------------------------
# AI Providers — Text-to-Speech
# ------------------------------------------------------------------------------
ELEVENLABS_API_KEY=...

# AWS Polly (TTS fallback)
AWS_POLLY_ACCESS_KEY_ID=AKIA...
AWS_POLLY_SECRET_ACCESS_KEY=...
AWS_POLLY_REGION=us-east-1

# ------------------------------------------------------------------------------
# Storage — Cloudflare R2 (S3-compatible)
# ------------------------------------------------------------------------------
CLOUDFLARE_R2_ACCOUNT_ID=...
CLOUDFLARE_R2_ACCESS_KEY_ID=...
CLOUDFLARE_R2_SECRET_ACCESS_KEY=...
CLOUDFLARE_R2_BUCKET_NAME=fvos-media
# Public URL for serving assets (custom domain or r2.dev URL)
CLOUDFLARE_R2_PUBLIC_URL=https://media.yourdomain.com

# ------------------------------------------------------------------------------
# Social Platform OAuth — YouTube
# ------------------------------------------------------------------------------
YOUTUBE_CLIENT_ID=...
YOUTUBE_CLIENT_SECRET=...
YOUTUBE_REDIRECT_URI=http://localhost:3001/api/v1/oauth/youtube/callback

# ------------------------------------------------------------------------------
# Social Platform OAuth — TikTok
# ------------------------------------------------------------------------------
TIKTOK_CLIENT_KEY=...
TIKTOK_CLIENT_SECRET=...
TIKTOK_REDIRECT_URI=http://localhost:3001/api/v1/oauth/tiktok/callback

# ------------------------------------------------------------------------------
# Social Platform OAuth — Instagram / Meta
# ------------------------------------------------------------------------------
INSTAGRAM_APP_ID=...
INSTAGRAM_APP_SECRET=...
INSTAGRAM_REDIRECT_URI=http://localhost:3001/api/v1/oauth/instagram/callback

# ------------------------------------------------------------------------------
# Notifications
# ------------------------------------------------------------------------------
# Resend (transactional email)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@yourdomain.com

# Slack (ops alerts + notifications)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ------------------------------------------------------------------------------
# Cost Governance
# ------------------------------------------------------------------------------
# Set to "true" to enable hard budget stops (will reject jobs when over budget)
COST_HARD_STOP_ENABLED=true

# Default tier for new channels if not specified
# One of: FREE | ECONOMICAL | OPTIMIZED | PREMIUM | ULTRA
DEFAULT_TIER=ECONOMICAL

# ------------------------------------------------------------------------------
# (Development Only) MinIO — local S3/R2 emulation
# ------------------------------------------------------------------------------
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=fvos-local
MINIO_USE_SSL=false
