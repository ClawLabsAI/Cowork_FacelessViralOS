# ============================================================
# Faceless Viral OS — Video Engine (Railway)
# Python + FFmpeg + MoviePy + edge-tts + OpenAI
# ============================================================

FROM python:3.11-slim

# Install FFmpeg + ImageMagick (required by MoviePy)
RUN apt-get update -y \
  && apt-get install -y ffmpeg imagemagick fonts-dejavu-core \
  && rm -rf /var/lib/apt/lists/*

# Allow ImageMagick to read/write video files (policy fix)
RUN sed -i 's/rights="none" pattern="PDF"/rights="read|write" pattern="PDF"/' /etc/ImageMagick-6/policy.xml 2>/dev/null || true

WORKDIR /app

COPY apps/video-engine/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY apps/video-engine/src/ ./src/

ENV WORK_DIR=/tmp/fvos-videos
ENV PYTHONUNBUFFERED=1

EXPOSE 8000

CMD ["python", "src/main.py"]
