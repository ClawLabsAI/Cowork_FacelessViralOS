# ============================================================
# Faceless Viral OS — Next.js Dashboard (Railway)
# ============================================================
# Root dir must be /scaffolding so pnpm workspaces can resolve
# @fvos/core and other workspace packages.
# ============================================================

FROM node:20-slim

RUN apt-get update -y \
  && apt-get install -y openssl \
  && rm -rf /var/lib/apt/lists/*

RUN npm install -g pnpm@9

WORKDIR /app

COPY . .

RUN pnpm install

# Build @fvos/core first (web depends on it)
RUN pnpm --filter @fvos/core build

# Build the Next.js app
RUN pnpm --filter @fvos/web build

EXPOSE 3000

CMD pnpm --filter @fvos/web start
