// ============================================================
// Faceless Viral OS — Prisma Schema
// Single source of truth for all database models and relations.
// Run: pnpm --filter @fvos/db db:migrate
// ============================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER

  @@map("user_role")
}

enum ChannelStatus {
  ACTIVE
  PAUSED
  ARCHIVED
  SETUP

  @@map("channel_status")
}

enum TierName {
  FREE
  STARTER
  PRO
  AGENCY

  @@map("tier_name")
}

enum TaskType {
  SCRIPT_GENERATION
  SCENE_PROMPT_GENERATION
  IDEA_GENERATION
  NICHE_RESEARCH
  COMPETITOR_ANALYSIS
  TTS_GENERATION
  IMAGE_GENERATION
  VIDEO_RENDER
  PLATFORM_PUBLISH
  ANALYTICS_INGEST

  @@map("task_type")
}

enum JobStatus {
  WAITING
  ACTIVE
  COMPLETED
  FAILED
  DELAYED
  CANCELLED

  @@map("job_status")
}

enum Platform {
  YOUTUBE
  YOUTUBE_SHORTS
  TIKTOK
  INSTAGRAM_REELS
  FACEBOOK_REELS
  SNAPCHAT

  @@map("platform")
}

enum Language {
  EN
  ES
  FR
  DE
  PT
  JA
  KO
  ZH
  HI
  AR

  @@map("language")
}

enum AssetType {
  AUDIO_TTS
  AUDIO_MUSIC
  IMAGE_SCENE
  IMAGE_THUMBNAIL
  VIDEO_RAW
  VIDEO_ADAPTED
  VIDEO_INTRO
  VIDEO_OUTRO

  @@map("asset_type")
}

enum VideoStatus {
  DRAFT
  RENDERING
  RENDER_FAILED
  READY
  PUBLISHED
  ARCHIVED

  @@map("video_status")
}

enum PublishStatus {
  SCHEDULED
  QUEUED
  PUBLISHING
  PUBLISHED
  FAILED
  CANCELLED

  @@map("publish_status")
}

enum BudgetPeriod {
  DAILY
  WEEKLY
  MONTHLY

  @@map("budget_period")
}

enum TriggerType {
  CRON
  EVENT
  MANUAL
  WEBHOOK

  @@map("trigger_type")
}

enum ActionType {
  GENERATE_SCRIPT
  RENDER_VIDEO
  PUBLISH_VIDEO
  SEND_ALERT
  PAUSE_CHANNEL

  @@map("action_type")
}

enum ProviderType {
  LLM
  TTS
  IMAGE_GEN
  EMBEDDING

  @@map("provider_type")
}

enum ProviderHealth {
  HEALTHY
  DEGRADED
  DOWN
  UNKNOWN

  @@map("provider_health")
}

// ============================================================
// MODELS
// ============================================================

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  passwordHash   String    @map("password_hash")
  displayName    String    @map("display_name")
  avatarUrl      String?   @map("avatar_url")
  externalId     String?   @unique @map("external_id") // Reserved for Phase 2 Auth0 migration
  emailVerified  Boolean   @default(false) @map("email_verified")
  lastLoginAt    DateTime? @map("last_login_at")
  refreshToken   String?   @map("refresh_token")          // Hashed refresh token
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  memberships    Membership[]

  @@index([email])
  @@map("users")
}

model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logoUrl     String?  @map("logo_url")
  tier        TierName @default(FREE)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  memberships       Membership[]
  brands            Brand[]
  channels          Channel[]
  contentIdeas      ContentIdea[]
  automationRules   AutomationRule[]
  budgets           Budget[]
  tierProfile       TierProfile?
  costLedgerEntries CostLedger[]

  @@index([slug])
  @@map("workspaces")
}

model Membership {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  workspaceId String    @map("workspace_id")
  role        UserRole  @default(VIEWER)
  invitedAt   DateTime  @default(now()) @map("invited_at")
  acceptedAt  DateTime? @map("accepted_at")

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
  @@map("memberships")
}

model Brand {
  id          String    @id @default(cuid())
  workspaceId String    @map("workspace_id")
  name        String
  voiceTone   String?   @map("voice_tone")  // e.g. "authoritative", "friendly", "dramatic"
  colorPrimary String?  @map("color_primary")
  colorSecondary String? @map("color_secondary")
  fontHeading String?   @map("font_heading")
  logoUrl     String?   @map("logo_url")
  introVideoKey String? @map("intro_video_key") // R2 key for branded intro clip
  outroVideoKey String? @map("outro_video_key") // R2 key for branded outro clip
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channels    Channel[]

  @@index([workspaceId])
  @@map("brands")
}

model Channel {
  id            String        @id @default(cuid())
  workspaceId   String        @map("workspace_id")
  brandId       String?       @map("brand_id")
  name          String
  slug          String        @map("slug")
  description   String?
  status        ChannelStatus @default(SETUP)
  language      Language      @default(EN)
  targetNiches  String[]      @map("target_niches")
  publishingCadence Int?      @map("publishing_cadence") // target videos per week
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  workspace         Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  brand             Brand?             @relation(fields: [brandId], references: [id])
  platformAccounts  PlatformAccount[]
  niches            Niche[]
  contentPillars    ContentPillar[]
  contentIdeas      ContentIdea[]
  scripts           Script[]
  videos            Video[]
  analyticsSnapshots AnalyticsSnapshot[]
  competitorChannels CompetitorChannel[]
  channelInsights   ChannelInsight[]
  monetizationLinks MonetizationLink[]
  trends            Trend[]

  @@unique([workspaceId, slug])
  @@index([workspaceId])
  @@index([status])
  @@map("channels")
}

model PlatformAccount {
  id               String   @id @default(cuid())
  channelId        String   @map("channel_id")
  platform         Platform
  platformChannelId String  @map("platform_channel_id") // e.g. YouTube channel ID
  handle           String?
  accessToken      String?  @map("access_token")   // Encrypted
  refreshToken     String?  @map("refresh_token")  // Encrypted
  tokenExpiresAt   DateTime? @map("token_expires_at")
  isActive         Boolean  @default(true) @map("is_active")
  lastPublishedAt  DateTime? @map("last_published_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  channel          Channel    @relation(fields: [channelId], references: [id], onDelete: Cascade)
  publishJobs      PublishJob[]

  @@unique([channelId, platform])
  @@index([channelId])
  @@map("platform_accounts")
}

model Niche {
  id          String   @id @default(cuid())
  channelId   String   @map("channel_id")
  name        String
  description String?
  searchVolume Int?    @map("search_volume")
  competition  Float?  // 0.0–1.0
  cpm          Float?  // estimated CPM in USD
  isActive     Boolean @default(true) @map("is_active")
  researchedAt DateTime? @map("researched_at")
  createdAt   DateTime @default(now()) @map("created_at")

  channel     Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  contentIdeas ContentIdea[]

  @@index([channelId])
  @@map("niches")
}

model Trend {
  id          String   @id @default(cuid())
  channelId   String   @map("channel_id")
  keyword     String
  score       Float    // trending score from data source
  dataSource  String   @map("data_source") // e.g. "google-trends", "youtube-trending"
  detectedAt  DateTime @map("detected_at")
  expiresAt   DateTime? @map("expires_at")
  metadata    Json?    // raw data from data source

  channel     Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId, detectedAt])
  @@map("trends")
}

model CompetitorChannel {
  id               String   @id @default(cuid())
  channelId        String   @map("channel_id")   // Our channel doing the monitoring
  platform         Platform
  platformChannelId String  @map("platform_channel_id")
  name             String
  subscriberCount  Int?     @map("subscriber_count")
  videoCount       Int?     @map("video_count")
  avgViewsLast30d  Int?     @map("avg_views_last_30d")
  topFormats       String[] @map("top_formats")
  lastAnalyzedAt   DateTime? @map("last_analyzed_at")
  createdAt        DateTime @default(now()) @map("created_at")

  channel          Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId])
  @@map("competitor_channels")
}

model ChannelInsight {
  id            String   @id @default(cuid())
  channelId     String   @map("channel_id")
  summary       String   // AI-generated strategic summary
  strengths     String[] // identified content strengths
  opportunities String[] // identified growth opportunities
  recommendations Json   // structured AI recommendations
  generatedAt   DateTime @default(now()) @map("generated_at")

  channel       Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId, generatedAt])
  @@map("channel_insights")
}

model ContentPillar {
  id          String   @id @default(cuid())
  channelId   String   @map("channel_id")
  name        String   // e.g. "Educational", "Trending", "Evergreen"
  description String?
  percentage  Int      // target % of content mix (must sum to 100 across channel)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  channel     Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  contentIdeas ContentIdea[]

  @@index([channelId])
  @@map("content_pillars")
}

model ContentIdea {
  id           String   @id @default(cuid())
  workspaceId  String   @map("workspace_id")
  channelId    String   @map("channel_id")
  nicheId      String?  @map("niche_id")
  pillarId     String?  @map("pillar_id")
  title        String
  hook         String?  // attention-grabbing first line
  angle        String?  // unique angle / differentiation
  keywords     String[]
  estimatedViews Int?   @map("estimated_views")
  status       String   @default("PENDING") // PENDING | APPROVED | REJECTED | SCRIPTED | ARCHIVED
  rejectionReason String? @map("rejection_reason")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channel      Channel       @relation(fields: [channelId], references: [id], onDelete: Cascade)
  niche        Niche?        @relation(fields: [nicheId], references: [id])
  pillar       ContentPillar? @relation(fields: [pillarId], references: [id])
  scripts      Script[]

  @@index([channelId, status])
  @@index([workspaceId])
  @@map("content_ideas")
}

model Script {
  id            String   @id @default(cuid())
  channelId     String   @map("channel_id")
  ideaId        String?  @map("idea_id")
  title         String
  hook          String   // opening hook (first 3 seconds)
  body          String   // main script body
  callToAction  String?  @map("call_to_action")
  estimatedDuration Int? @map("estimated_duration") // in seconds
  wordCount     Int?     @map("word_count")
  language      Language @default(EN)
  status        String   @default("DRAFT") // DRAFT | REVIEW | APPROVED | REJECTED | ARCHIVED
  rejectionNote String?  @map("rejection_note")
  approvedAt    DateTime? @map("approved_at")
  approvedBy    String?  @map("approved_by") // userId
  generatedBy   String?  @map("generated_by") // model ID used
  promptVersion String?  @map("prompt_version")
  inputTokens   Int?     @map("input_tokens")
  outputTokens  Int?     @map("output_tokens")
  costUsd       Float?   @map("cost_usd")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  channel       Channel      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  idea          ContentIdea? @relation(fields: [ideaId], references: [id])
  scenes        ScriptScene[]
  videos        Video[]

  @@index([channelId, status])
  @@map("scripts")
}

model ScriptScene {
  id           String   @id @default(cuid())
  scriptId     String   @map("script_id")
  sceneNumber  Int      @map("scene_number")
  narration    String   // spoken text for this scene
  visualPrompt String?  @map("visual_prompt") // AI image/B-roll prompt
  durationSec  Float?   @map("duration_sec")
  keywords     String[]
  createdAt    DateTime @default(now()) @map("created_at")

  script       Script   @relation(fields: [scriptId], references: [id], onDelete: Cascade)

  @@index([scriptId])
  @@map("script_scenes")
}

model VoiceProfile {
  id            String  @id @default(cuid())
  name          String
  provider      String  // "elevenlabs" | "openai"
  externalVoiceId String @map("external_voice_id") // provider's voice ID
  gender        String? // "male" | "female" | "neutral"
  accent        String? // "american" | "british" | etc.
  style         String? // "narrative" | "conversational" | "dramatic"
  previewUrl    String? @map("preview_url")
  isDefault     Boolean @default(false) @map("is_default")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([provider])
  @@map("voice_profiles")
}

model Asset {
  id          String    @id @default(cuid())
  channelId   String    @map("channel_id")
  type        AssetType
  r2Key       String    @map("r2_key")          // Cloudflare R2 object key
  r2Bucket    String    @map("r2_bucket")
  mimeType    String    @map("mime_type")
  sizeBytes   BigInt?   @map("size_bytes")
  durationSec Float?    @map("duration_sec")     // for audio/video assets
  width       Int?
  height      Int?
  metadata    Json?     // provider-specific metadata
  uploadedAt  DateTime  @default(now()) @map("uploaded_at")

  channel     Channel   @relation(fields: [channelId], references: [id])
  videoScenes VideoScene[]

  @@index([channelId, type])
  @@map("assets")
}

// Alias for forward relation without circular dependency
model VideoScene {
  id          String  @id @default(cuid())
  videoId     String  @map("video_id")
  assetId     String  @map("asset_id")
  sceneNumber Int     @map("scene_number")
  startTimeSec Float  @map("start_time_sec")
  durationSec Float   @map("duration_sec")

  video       Video   @relation(fields: [videoId], references: [id], onDelete: Cascade)
  asset       Asset   @relation(fields: [assetId], references: [id])

  @@index([videoId])
  @@map("video_scenes")
}

model Video {
  id              String      @id @default(cuid())
  channelId       String      @map("channel_id")
  scriptId        String      @map("script_id")
  title           String
  status          VideoStatus @default(DRAFT)
  renderJobId     String?     @map("render_job_id") // BullMQ job ID
  renderStartedAt DateTime?   @map("render_started_at")
  renderCompletedAt DateTime? @map("render_completed_at")
  renderError     String?     @map("render_error")
  durationSec     Float?      @map("duration_sec")
  voiceProfileId  String?     @map("voice_profile_id")
  backgroundMusicKey String?  @map("background_music_key") // R2 key
  musicVolume     Float?      @map("music_volume") // 0.0–1.0
  captionsEnabled Boolean     @default(true) @map("captions_enabled")
  thumbnailAssetId String?    @map("thumbnail_asset_id")
  winnerScore     Float?      @map("winner_score") // set by winner-identification job
  isWinner        Boolean     @default(false) @map("is_winner")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  channel         Channel       @relation(fields: [channelId], references: [id], onDelete: Cascade)
  script          Script        @relation(fields: [scriptId], references: [id])
  variants        VideoVariant[]
  scenes          VideoScene[]
  publishJobs     PublishJob[]

  @@index([channelId, status])
  @@index([isWinner])
  @@map("videos")
}

model VideoVariant {
  id          String   @id @default(cuid())
  videoId     String   @map("video_id")
  platform    Platform
  r2Key       String   @map("r2_key")
  r2Bucket    String   @map("r2_bucket")
  width       Int
  height      Int
  fps         Int
  bitrateKbps Int      @map("bitrate_kbps")
  durationSec Float    @map("duration_sec")
  sizeBytes   BigInt   @map("size_bytes")
  createdAt   DateTime @default(now()) @map("created_at")

  video       Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  publishJobs PublishJob[]

  @@unique([videoId, platform])
  @@index([videoId])
  @@map("video_variants")
}

model PublishJob {
  id                String        @id @default(cuid())
  videoId           String        @map("video_id")
  variantId         String        @map("variant_id")
  platformAccountId String        @map("platform_account_id")
  platform          Platform
  status            PublishStatus @default(SCHEDULED)
  scheduledAt       DateTime?     @map("scheduled_at")
  publishedAt       DateTime?     @map("published_at")
  platformPostId    String?       @map("platform_post_id") // e.g. YouTube video ID after publish
  platformPostUrl   String?       @map("platform_post_url")
  title             String?
  description       String?
  tags              String[]
  errorMessage      String?       @map("error_message")
  attempts          Int           @default(0)
  bullJobId         String?       @map("bull_job_id")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  video             Video           @relation(fields: [videoId], references: [id], onDelete: Cascade)
  variant           VideoVariant    @relation(fields: [variantId], references: [id])
  platformAccount   PlatformAccount @relation(fields: [platformAccountId], references: [id])

  @@index([videoId])
  @@index([platformAccountId, status])
  @@index([scheduledAt])
  @@map("publish_jobs")
}

model AnalyticsSnapshot {
  id          String   @id @default(cuid())
  channelId   String   @map("channel_id")
  platform    Platform
  snapshotAt  DateTime @map("snapshot_at")
  views       Int      @default(0)
  likes       Int      @default(0)
  comments    Int      @default(0)
  shares      Int      @default(0)
  subscribers Int      @default(0)
  watchTimeMin Int?    @map("watch_time_min")
  revenue     Float?   // estimated revenue in USD
  metadata    Json?    // platform-specific additional metrics

  channel     Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId, snapshotAt])
  @@index([channelId, platform])
  @@map("analytics_snapshots")
}

model AutomationRule {
  id          String      @id @default(cuid())
  workspaceId String      @map("workspace_id")
  name        String
  isActive    Boolean     @default(true) @map("is_active")
  triggerType TriggerType @map("trigger_type")
  triggerConfig Json      @map("trigger_config") // cron expression or event config
  actionType  ActionType  @map("action_type")
  actionConfig Json       @map("action_config") // action parameters
  lastRunAt   DateTime?   @map("last_run_at")
  nextRunAt   DateTime?   @map("next_run_at")
  runCount    Int         @default(0) @map("run_count")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, isActive])
  @@map("automation_rules")
}

model MonetizationLink {
  id          String  @id @default(cuid())
  channelId   String  @map("channel_id")
  name        String  // e.g. "Amazon Affiliate", "Course Link"
  url         String
  utmSource   String? @map("utm_source")
  utmMedium   String? @map("utm_medium")
  utmCampaign String? @map("utm_campaign")
  clickCount  Int     @default(0) @map("click_count")
  isActive    Boolean @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  channel     Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId])
  @@map("monetization_links")
}

model Provider {
  id          String         @id @default(cuid())
  name        String         @unique // e.g. "openai", "anthropic"
  displayName String         @map("display_name")
  type        ProviderType
  baseUrl     String?        @map("base_url")
  health      ProviderHealth @default(UNKNOWN)
  lastHealthCheck DateTime?  @map("last_health_check")
  isEnabled   Boolean        @default(true) @map("is_enabled")
  metadata    Json?          // additional provider config
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  models      Model[]

  @@index([type, isEnabled])
  @@map("providers")
}

model Model {
  id              String   @id @default(cuid())
  providerId      String   @map("provider_id")
  modelId         String   @map("model_id") // e.g. "gpt-4o", "claude-3-5-sonnet-20241022"
  displayName     String   @map("display_name")
  contextWindow   Int      @map("context_window") // in tokens
  maxOutputTokens Int      @map("max_output_tokens")
  inputPricePerMToken  Float @map("input_price_per_m_token")  // USD per 1M input tokens
  outputPricePerMToken Float @map("output_price_per_m_token") // USD per 1M output tokens
  supportsStreaming Boolean @default(true) @map("supports_streaming")
  supportsVision   Boolean @default(false) @map("supports_vision")
  isEnabled        Boolean @default(true) @map("is_enabled")
  tier             TierName @default(PRO) // minimum tier required to use this model
  createdAt        DateTime @default(now()) @map("created_at")

  provider         Provider @relation(fields: [providerId], references: [id])

  @@unique([providerId, modelId])
  @@index([providerId, isEnabled])
  @@map("models")
}

model TierProfile {
  id                   String   @id @default(cuid())
  workspaceId          String   @unique @map("workspace_id")
  tier                 TierName
  defaultScriptModel   String   @map("default_script_model")   // e.g. "gpt-4o"
  defaultIdeaModel     String   @map("default_idea_model")
  defaultResearchModel String   @map("default_research_model")
  defaultTtsProvider   String   @map("default_tts_provider")
  maxVideosPerMonth    Int?     @map("max_videos_per_month")
  maxChannels          Int?     @map("max_channels")
  priorityMultiplier   Float    @default(1.0) @map("priority_multiplier") // queue priority boost
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  workspace            Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("tier_profiles")
}

model RoutingPolicy {
  id           String   @id @default(cuid())
  name         String
  description  String?
  isDefault    Boolean  @default(false) @map("is_default")
  rules        Json     // Array of RoutingRule: { taskType, tier, providers, models, fallbackChain }
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("routing_policies")
}

model CostLedger {
  id            String   @id @default(cuid())
  workspaceId   String   @map("workspace_id")
  taskType      TaskType @map("task_type")
  provider      String   // provider name
  modelId       String   @map("model_id")
  inputTokens   Int?     @map("input_tokens")
  outputTokens  Int?     @map("output_tokens")
  characters    Int?     // for TTS billing
  units         Float?   // generic units for other billing models
  costUsd       Float    @map("cost_usd")
  jobId         String?  @map("job_id") // BullMQ job ID for traceability
  traceId       String?  @map("trace_id") // OTel trace ID
  entityId      String?  @map("entity_id") // scriptId, videoId, etc.
  entityType    String?  @map("entity_type") // "Script" | "Video" | etc.
  recordedAt    DateTime @default(now()) @map("recorded_at")

  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, recordedAt])
  @@index([workspaceId, taskType])
  @@index([workspaceId, provider])
  @@map("cost_ledger")
}

model Budget {
  id              String       @id @default(cuid())
  workspaceId     String       @map("workspace_id")
  name            String
  limitUsd        Float        @map("limit_usd")
  period          BudgetPeriod
  spentUsd        Float        @default(0) @map("spent_usd")
  utilizationPct  Float        @default(0) @map("utilization_pct")
  alertAt80       Boolean      @default(true) @map("alert_at_80")
  alertAt95       Boolean      @default(true) @map("alert_at_95")
  hardStop        Boolean      @default(true) @map("hard_stop") // block requests when 100% reached
  periodStartsAt  DateTime     @map("period_starts_at")
  periodEndsAt    DateTime     @map("period_ends_at")
  lastRecalcAt    DateTime?    @map("last_recalc_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  workspace       Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  usageRecords    UsageRecord[]

  @@index([workspaceId, periodEndsAt])
  @@map("budgets")
}

model UsageRecord {
  id          String   @id @default(cuid())
  budgetId    String   @map("budget_id")
  taskType    TaskType @map("task_type")
  amountUsd   Float    @map("amount_usd")
  recordedAt  DateTime @default(now()) @map("recorded_at")

  budget      Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@index([budgetId, recordedAt])
  @@map("usage_records")
}
